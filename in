            </button>
        </div>

        <div id="history-section" class="app-page px-5 pt-6">
            <div class="flex items-center gap-4 mb-6">
                <button onclick="window.showPage('home-section')" class="bg-white p-3 rounded-2xl shadow-sm border text-indigo-600"><i class="fa-solid fa-chevron-left"></i></button>
                <h1 class="text-2xl font-black text-slate-800 uppercase italic">Report History</h1>
            </div>
            
            <div class="setup-card !p-4 bg-indigo-50 border-none">
                <input type="date" id="searchDateInput" class="large-input !text-sm !mb-2">
                <select id="searchGroupFilter" class="large-input !text-sm !mb-2"></select>
                <button id="searchHistoryBtn" class="w-full bg-indigo-600 text-white py-4 rounded-2xl font-black shadow-lg uppercase text-xs">সার্চ রিপোর্ট</button>
            </div>
            
            <div id="history-data" class="space-y-4"></div>
        </div>

        <div id="detail-section" class="app-page px-5 pt-6">
            <div class="flex justify-between items-center mb-4">
                <button onclick="window.showPage('history-section')" class="bg-white p-3 rounded-2xl shadow-sm border text-indigo-600"><i class="fa-solid fa-arrow-left"></i></button>
                <button id="downloadPdfBtn" class="bg-emerald-600 text-white px-6 py-4 rounded-2xl text-sm font-black uppercase shadow-lg"><i class="fa-solid fa-file-pdf mr-2"></i> PDF</button>
            </div>

            <div id="invoice-print" class="bg-white p-6 rounded-[2.5rem] border shadow-xl mb-6">
                <div class="text-center border-b-2 border-slate-50 pb-6 mb-6">
                    <h2 class="text-3xl font-black italic text-indigo-700 tracking-tighter">DUE LIST</h2>
                    <p id="inv-date" class="text-[10px] font-bold text-slate-400 uppercase mt-2"></p>
                </div>
                <div class="mb-6">
                    <p class="text-[9px] text-slate-400 uppercase font-black tracking-widest mb-1">Customer</p>
                    <p id="inv-chemist" class="text-2xl font-black uppercase text-slate-800 italic leading-none"></p>
                </div>
                <table class="order-table">
                    <thead>
                        <tr>
                            <th>Medicine</th>
                            <th class="text-center">Qty</th>
                            <th class="no-pdf text-center">X</th>
                        </tr>
                    </thead>
                    <tbody id="inv-items-table-body"></tbody>
                </table>
            </div>
            
            <div class="setup-card !p-6 border-l-8 border-orange-500">
                <p class="text-[10px] font-black text-orange-500 uppercase mb-4 tracking-widest">নতুন আইটেম যোগ বা ইডিট করুন</p>
                <div class="space-y-4">
                    <input type="text" id="edit-p-name" list="med-list-data" placeholder="মেডিসিনের নাম..." class="large-input">
                    <input type="number" id="edit-p-qty" placeholder="পরিমাণ (Qty)" class="large-input">
                    <button id="addItemToExistingBtn" class="save-btn bg-orange-500 shadow-xl shadow-orange-100 flex items-center justify-center gap-2">
                        <i class="fa-solid fa-plus text-xl"></i> আইটেম আপডেট করুন
                    </button>
                </div>
            </div>
        </div>

        <div id="chemist-section" class="app-page px-5 pt-6">
            <div class="flex items-center gap-4 mb-6">
                <button onclick="window.showPage('home-section')" class="bg-white p-3 rounded-2xl shadow-sm border text-indigo-600"><i class="fa-solid fa-chevron-left"></i></button>
                <h1 class="text-xl font-black text-slate-800 uppercase">Chemist List</h1>
            </div>
            <input type="text" id="customerSearchInput" placeholder="সার্চ করুন..." class="large-input !text-sm">
            <div id="chemist-list" class="space-y-3"></div>
        </div>

        <div id="settings-section" class="app-page px-5 pt-6">
            <div class="flex items-center gap-4 mb-6">
                <button onclick="window.showPage('home-section')" class="bg-white p-3 rounded-2xl shadow-sm border text-slate-500"><i class="fa-solid fa-chevron-left"></i></button>
                <h1 class="text-xl font-black text-slate-800 uppercase">Settings</h1>
            </div>
            <div class="setup-card">
                <h3 class="text-[10px] font-black text-indigo-600 uppercase mb-3">Add Group</h3>
                <div class="flex gap-2"><input type="text" id="gInput" placeholder="Ex: GB-1" class="!mb-0 !p-3 rounded-xl"><button id="addGroupBtn" class="bg-slate-900 text-white px-5 rounded-xl font-black">ADD</button></div>
                <div id="gList" class="mt-4 flex flex-wrap gap-2"></div>
            </div>
        </div>
    </div>

    <datalist id="med-list-data"></datalist>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, doc, setDoc, onSnapshot, updateDoc, arrayUnion, arrayRemove, collection, addDoc, getDocs, query, where } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyAzwqWUuMyW8piPhkFRhcpnmcpbu_0-lvk",
            authDomain: "sharif-pharma.firebaseapp.com",
            projectId: "sharif-pharma",
            storageBucket: "sharif-pharma.firebasestorage.app",
            messagingSenderId: "867521349666",
            appId: "1:867521349666:web:a8d139d5c41690e910227b"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const DOC_REF = doc(db, "settings", "app_data");

        let masterGroups = [], allCustomers = [], allMedicines = [], cart = [], currentGroup = '', currentChemist = '', activeFilter = '', currentOrderId = '', currentOrderData = null;

        window.showPage = (id) => { document.querySelectorAll('.app-page').forEach(p => p.classList.remove('active')); document.getElementById(id).classList.add('active'); window.scrollTo(0,0); };

        onSnapshot(DOC_REF, (snap) => {
            const data = snap.exists() ? snap.data() : { groups: [], customers: [], medicines: [] };
            masterGroups = data.groups || [];
            allCustomers = data.customers || [];
            allMedicines = data.medicines || [];
            renderAdminUI();
        });

        function renderAdminUI() {
            document.getElementById('main-group-list').innerHTML = masterGroups.map(g => `
                <button onclick="window.showChemists('${g}')" class="main-action-btn">
                    <div class="text-indigo-600 mb-2"><i class="fa-solid fa-folder-open text-3xl"></i></div>
                    <div class="font-black text-slate-800 text-sm uppercase">${g}</div>
                </button>
            `).join('');
            document.getElementById('searchGroupFilter').innerHTML = '<option value="ALL">All Groups</option>' + masterGroups.map(g => `<option value="${g}">${g}</option>`).join('');
            document.getElementById('med-list-data').innerHTML = allMedicines.map(m => `<option value="${m}">`).join('');
            document.getElementById('gList').innerHTML = masterGroups.map(g => `<div class="bg-white p-2 rounded-lg text-xs font-bold border">${g}</div>`).join('');
        }

        window.showChemists = (g) => {
            currentGroup = g; 
            window.showPage('chemist-section');
            const groupCustomers = allCustomers.filter(c => c.group === g);
            document.getElementById('chemist-list').innerHTML = groupCustomers.map(c => `<button onclick="window.openForm('${c.name}')" class="w-full text-left p-6 bg-white border border-slate-100 rounded-[2rem] font-black text-slate-700 shadow-sm uppercase active:scale-95 transition-all">${c.name}</button>`).join('');
        };

        window.openForm = (name) => { currentChemist = name; cart = []; renderCart(); document.getElementById('selected-chemist-name').innerText = name; window.showPage('form-section'); };
        
        document.getElementById('addToCartBtn').onclick = () => {
            const p = document.getElementById('product-name').value, q = document.getElementById('quantity').value;
            if(!p || !q) return;
            cart.push({product: p, qty: q});
            document.getElementById('product-name').value = ''; document.getElementById('quantity').value = ''; renderCart();
        };

        function renderCart() { 
            document.getElementById('cart-count').innerText = cart.length;
            document.getElementById('cart-items').innerHTML = cart.map((item, i) => `<tr class="flex justify-between items-center p-5"><td class="font-bold text-lg uppercase">${item.product}</td><td class="font-black text-indigo-600 bg-indigo-50 px-4 py-2 rounded-xl text-lg">x${item.qty}</td><td><button onclick="window.removeCartItem(${i})" class="text-red-400 p-2">✕</button></td></tr>`).join(''); 
        }
        window.removeCartItem = (i) => { cart.splice(i,1); renderCart(); };

        document.getElementById('saveOrderBtn').onclick = async () => {
            if(!cart.length) return alert("তালিকা খালি!");
            const date = new Intl.DateTimeFormat('en-CA', {timeZone:'Asia/Dhaka'}).format(new Date());
            await addDoc(collection(db, "orders"), { group: currentGroup, chemist: currentChemist, items: cart, date: date });
            alert("অর্ডার সেভ হয়েছে!"); window.showPage('home-section');
        };

        document.getElementById('searchHistoryBtn').onclick = async () => {
            const date = document.getElementById('searchDateInput').value, group = document.getElementById('searchGroupFilter').value;
            if(!date) return alert("তারিখ দিন");
            const snap = await getDocs(query(collection(db, "orders"), where("date", "==", date)));
            const container = document.getElementById('history-data');
            container.innerHTML = '';
            snap.forEach(d => {
                const data = d.data();
                if(group === "ALL" || data.group === group) {
                    container.innerHTML += `<div onclick="window.openDetail('${d.id}')" class="setup-card flex justify-between items-center cursor-pointer !p-6 border-l-8 border-indigo-600"><div><p class="font-black text-slate-800 uppercase text-xl italic">${data.chemist}</p><p class="text-[10px] font-bold text-slate-400 mt-1 uppercase">${data.group} • ${data.items.length} Items</p></div><i class="fa-solid fa-chevron-right text-slate-300"></i></div>`;
                }
            });
        };

        window.openDetail = (id) => {
            currentOrderId = id;
            onSnapshot(doc(db, "orders", id), (snap) => {
                if(!snap.exists()) return;
                currentOrderData = snap.data();
                document.getElementById('inv-date').innerText = currentOrderData.date;
                document.getElementById('inv-chemist').innerText = currentOrderData.chemist;
                document.getElementById('inv-items-table-body').innerHTML = currentOrderData.items.map((it, i) => `<tr><td class="uppercase">${it.product}</td><td class="text-center font-black text-indigo-600 text-lg">x${it.qty}</td><td class="no-pdf text-center"><button onclick="window.deleteItemFromOrder(${i})" class="text-red-300"><i class="fa-solid fa-trash"></i></button></td></tr>`).join('');
                window.showPage('detail-section');
            });
        };

        // এই বাটনের মাধ্যমে হিস্ট্রি পেজ থেকে নতুন আইটেম যোগ করা যাবে (বড় ফরম)
        document.getElementById('addItemToExistingBtn').onclick = async () => {
            const p = document.getElementById('edit-p-name').value, q = document.getElementById('edit-p-qty').value;
            if(p && q) {
                const updatedItems = [...currentOrderData.items, { product: p, qty: q }];
                await updateDoc(doc(db, "orders", currentOrderId), { items: updatedItems });
                document.getElementById('edit-p-name').value = ''; 
                document.getElementById('edit-p-qty').value = '';
                alert("আইটেম যোগ হয়েছে!");
            } else {
                alert("নাম এবং পরিমাণ দিন");
            }
        };

        window.deleteItemFromOrder = async (i) => { if(confirm("ডিলিট করবেন?")) await updateDoc(doc(db, "orders", currentOrderId), { items: currentOrderData.items.filter((_, idx) => idx !== i) }); };

        document.getElementById('downloadPdfBtn').onclick = () => {
            const element = document.getElementById('invoice-print');
            const noPdfElements = document.querySelectorAll('.no-pdf');
            noPdfElements.forEach(el => el.style.display = 'none');
            html2pdf().set({ margin: 10, filename: `${currentOrderData.chemist}.pdf`, html2canvas: { scale: 3, useCORS: true }, jsPDF: { unit: 'mm', format: 'a4' } }).from(element).save().then(() => noPdfElements.forEach(el => el.style.display = 'table-cell'));
        };
        
        document.getElementById('addGroupBtn').onclick = async () => {
            const v = document.getElementById('gInput').value.trim().toUpperCase();
            if(v) await updateDoc(DOC_REF, { groups: arrayUnion(v) });
            document.getElementById('gInput').value = '';
        };
    </script>
</body>
</html>

